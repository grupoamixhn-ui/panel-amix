# ──────────────────────────────────────────────────────────────────────────────
#  Flussonic Admin Panel — .gitignore
# ──────────────────────────────────────────────────────────────────────────────

# IDE / editors
.idea/
.vscode/
*.swp
*.swo

# OS junk
.DS_Store
Thumbs.db
*.pem

# ── Secrets (NEVER commit) ────────────────────────────────────────────────────
**/.env
**/.env.*
!**/.env.example
*token.json*
*credentials.json*
memory/test_credentials.md

# ── Python (backend) ──────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
backend/.venv/
backend/tests/__pycache__/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ── Node / React (frontend) ───────────────────────────────────────────────────
node_modules/
/node_modules
frontend/node_modules/
frontend/build/
frontend/.cache/
/.pnp
.pnp.js
.yarn/install-state.gz
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
backend/*.log
frontend/*.log
logs/

# ── Build artifacts / release tarballs (re-generated by make-release.sh) ──────
/build
build/
out/
dist/
*.tar.gz
*.tar
*.tgz
*.zip

# ── Test reports / iteration files ────────────────────────────────────────────
test_reports/
test_result.md
coverage/
.nyc_output/

# ── Emergent platform internals ───────────────────────────────────────────────
.emergent/

# ── MongoDB / databases ───────────────────────────────────────────────────────
dump.rdb
*.sqlite
*.db

# ── Caches ────────────────────────────────────────────────────────────────────
.cache/
.parcel-cache/
.next/
next-env.d.ts
*.tsbuildinfo

# ── Misc binaries ─────────────────────────────────────────────────────────────
*.pack
*.deb
*.dylib

# ── Local-only memory / scratch ───────────────────────────────────────────────
# Keep PRD.md tracked, hide everything else under memory/
memory/scratch/
frontend/node_modules/.cache/default-development/12.pack
frontend/node_modules/.cache/default-development/6.pack
.env
.env.*
*.env
credentials.json
*.key
.credentials
frontend/node_modules/.cache/default-development/11.pack
frontend/node_modules/.cache/default-development/13.pack
frontend/node_modules/.cache/default-development/14.pack
frontend/node_modules/.cache/default-development/15.pack
frontend/node_modules/.cache/default-development/8.pack
frontend/node_modules/.cache/default-development/16.pack
frontend/node_modules/.cache/default-development/20.pack
frontend/node_modules/.cache/default-development/10.pack
frontend/node_modules/.cache/default-development/2.pack
frontend/node_modules/.cache/default-development/25.pack
frontend/node_modules/.cache/default-development/26.pack
frontend/node_modules/.cache/default-development/21.pack
frontend/node_modules/.cache/default-development/1.pack
